def is_expiry(key=None):
    if key is None: key,_ = get_underlying()
    return now_ist().weekday() == UNDERLYINGS[key]["expiry_weekday"]

def oi_thresh(key):
    return (50_000,200_000,500_000) if key=="sensex" else (500_000,2_000_000,5_000_000)

